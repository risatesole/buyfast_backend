{
  "builds": [
    {
      "src": "config/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "config/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "config.settings",
    "DJANGO_ALLOWED_HOSTS": "buyfast-backend.vercel.app,localhost,127.0.0.1",
    "CSRF_TRUSTED_ORIGINS": "https://buyfast-backend.vercel.app,http://localhost:3000",
    "CORS_ALLOWED_ORIGINS": "https://buyfast-backend.vercel.app,http://localhost:3000"
  }
}
